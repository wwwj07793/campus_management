ENVIRONMENT=production

# Required in production. Generate a long random value and keep it secret.
CAMPUS_AUTH_SECRET=replace-with-a-long-random-secret

# Choose one database style.
# MySQL example:
DATABASE_URL=mysql+pymysql://user:password@host:3306/campus_db?charset=utf8mb4

# SQLite quick smoke-test example:
# DATABASE_URL=sqlite:///./campus.db

# Comma-separated frontend/API origins allowed to call this API.
# If frontend and API are served by the same FastAPI app, put that public domain here.
CORS_ORIGINS=https://your-domain.example.com

# Set true only for a small demo deployment where SQLAlchemy may create tables at startup.
# For production with migrations, prefer false and run Alembic migrations explicitly.
INIT_DB_ON_STARTUP=false

# Optional pool tuning for MySQL.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
